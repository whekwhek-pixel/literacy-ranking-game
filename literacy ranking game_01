            const el = document.getElementById(`line-node-l-${i}`);
            const r = el.getBoundingClientRect();
            lineEngineState.coordsLeft[i] = { x: r.right - bRect.left, y: (r.top + r.height/2) - bRect.top };
        });

        quiz.right.forEach((_, i) => {
            const el = document.getElementById(`line-node-r-${i}`);
            const r = el.getBoundingClientRect();
            lineEngineState.coordsRight[i] = { x: r.left - bRect.left, y: (r.top + r.height/2) - bRect.top };
        });
    }

    // 양방향 터치/마우스 완벽 대응 결합 스위치
    function handleDynamicNodeLinkInteraction(side, index) {
        const state = lineEngineState;
        
        // 이미 매칭 완료 수립된 대상 차단
        if(side === 'left' && Object.keys(state.connectedPairs).includes(String(index))) return;
        if(side === 'right' && Object.values(state.connectedPairs).includes(index)) return;

        if(state.selectedNode === null) {
            // 최초 선택 설정
            state.selectedNode = { side, index };
            highlightSelectedNodeElement(side, index, true);
        } else {
            // 두 번째 선택 - 동일 사이드 교체 또는 반대편 결합 시도 처리
            if(state.selectedNode.side === side) {
                highlightSelectedNodeElement(state.selectedNode.side, state.selectedNode.index, false);
                state.selectedNode = { side, index };
                highlightSelectedNodeElement(side, index, true);
            } else {
                // 양방향 결합 성공 유도 검사 (왼쪽->오른쪽 / 오른쪽->왼쪽 자유 매칭)
                const leftIdx = (side === 'left') ? index : state.selectedNode.index;
                const rightIdx = (side === 'right') ? index : state.selectedNode.index;
                const correctRightMatch = gameQuizDataset[playQuizIndex].pairs[leftIdx];

                if(rightIdx === correctRightMatch) {
                    triggerAudioNode('correct');
                    state.connectedPairs[leftIdx] = rightIdx;
                    
                    document.getElementById(`line-node-l-${leftIdx}`).className = "node-box linked-success";
                    document.getElementById(`line-node-r-${rightIdx}`).className = "node-box linked-success";
                    
                    highlightSelectedNodeElement(state.selectedNode.side, state.selectedNode.index, false);
                    state.selectedNode = null;
                    renderConfirmedCanvasLines();

                    // 전체 완료 조건 매칭 검사
                    const targetLen = Object.keys(gameQuizDataset[playQuizIndex].pairs).length;
                    if(Object.keys(state.connectedPairs).length === targetLen) {
                        clearInterval(countdownInterval);
                        processStandardAnswerJudgement(true, countdownTime);
                    }
                } else {
                    // 결합 실패 적색 에러선 플래시 연출
                    triggerAudioNode('wrong');
                    flashErrorCanvasLine(leftIdx, rightIdx);
                    highlightSelectedNodeElement(state.selectedNode.side, state.selectedNode.index, false);
                    state.selectedNode = null;
                }
            }
        }
    }

    function highlightSelectedNodeElement(side, idx, add) {
        const id = (side === 'left') ? `line-node-l-${idx}` : `line-node-r-${idx}`;
        const el = document.getElementById(id);
        if(el) {
            if(add) el.classList.add('selected');
            else el.classList.remove('selected');
        }
    }

    function renderConfirmedCanvasLines() {
        const canvas = document.getElementById('canvas-line-layer');
        if(!canvas) return;
        const ctx = canvas.getContext('2d');
        ctx.clearRect(0,0,canvas.width, canvas.height);

        ctx.lineWidth = 3.5; ctx.strokeStyle = "var(--main-green)";
        for(let l in lineEngineState.connectedPairs) {
            const r = lineEngineState.connectedPairs[l];
            const s = lineEngineState.coordsLeft[l]; const e = lineEngineState.coordsRight[r];
            if(s && e) {
                ctx.beginPath(); ctx.moveTo(s.x, s.y); ctx.lineTo(e.x, e.y); ctx.stroke();
            }
        }
    }

    function flashErrorCanvasLine(l, r) {
        const canvas = document.getElementById('canvas-line-layer');
        if(!canvas) return;
        const ctx = canvas.getContext('2d');
        const s = lineEngineState.coordsLeft[l]; const e = lineEngineState.coordsRight[r];

        if(s && e) {
            ctx.lineWidth = 4; ctx.strokeStyle = "var(--point-red)";
            ctx.beginPath(); ctx.moveTo(s.x, s.y); ctx.lineTo(e.x, e.y); ctx.stroke();
            setTimeout(() => { renderConfirmedCanvasLines(); }, 400);
        }
    }

    // 정/오답 판정 및 가치 가산 연출 시스템 (캐릭터 배제형 인포그래픽 중심)
    function processStandardAnswerJudgement(isCorrect, secondsLeft) {
        const flash = document.getElementById('feedback-flash-backdrop');
        const container = document.getElementById('game-viewport');

        if(isCorrect) {
            triggerAudioNode('correct');
            matchCorrectCount++; matchComboCombo++;
            if(matchComboCombo > matchMaxCombo) matchMaxCombo = matchComboCombo;

            let comboBonus = 0;
            if(matchComboCombo >= 10) comboBonus = 50;
            else if(matchComboCombo >= 7) comboBonus = 30;
            else if(matchComboCombo >= 5) comboBonus = 20;
            else if(matchComboCombo >= 3) comboBonus = 10;

            accumulativeScore += (100 + (secondsLeft * 2) + comboBonus);

            flash.className = "flash-screen correct-state";
            setTimeout(() => { flash.className = "flash-screen"; }, 350);

            // 독점식 콤보 팝업 트리거 작동 (중첩 금지 인터럽트 포함)
            if(matchComboCombo === 3) displayExclusiveComboBanner("3 COMBO", "GOOD! 👍");
            else if(matchComboCombo === 5) displayExclusiveComboBanner("5 COMBO", "GREAT! 🔥");
            else if(matchComboCombo === 7) displayExclusiveComboBanner("7 COMBO", "AWESOME! 😎");
            else if(matchComboCombo >= 10) displayExclusiveComboBanner(`${matchComboCombo} COMBO`, "LEGEND! 👑");

        } else {
            triggerAudioNode('wrong');
            matchComboCombo = 0; // 콤보 단절

            container.classList.add('shake-body');
            setTimeout(() => { container.classList.remove('shake-body'); }, 350);
        }

        setTimeout(() => {
            playQuizIndex++;
            pipelineCoreQuizScheduler();
        }, 900);
    }

    // 중첩이 차단된 순수 무결한 팝업 연출기
    function displayExclusiveComboBanner(title, sub) {
        triggerAudioNode('combo');
        const layer = document.getElementById('global-combo-layer');
        const box = document.getElementById('combo-neon-box');

        box.classList.remove('run-animation');
        void box.offsetWidth; // DOM 강제 리플로우 유도 트리거

        document.getElementById('text-combo-title').innerText = title;
        document.getElementById('text-combo-subtitle').innerText = sub;

        layer.style.display = 'flex';
        box.classList.add('run-animation');

        setTimeout(() => { layer.style.display = 'none'; }, 1500);
    }

    // --- 4. Firestore 레코드 전송 송신 파이프라인 ---
    function dispatchMatchDataToFirestore() {
        clearInterval(stopwatchInterval);
        clearInterval(countdownInterval);
        switchActiveScreen('screen-result');
        triggerAudioNode('finish');

        // 기본 정보 선매핑 표시
        document.getElementById('res-correct-cnt').innerText = `${matchCorrectCount} / ${gameQuizDataset.length}`;
        document.getElementById('res-max-combo').innerText = matchMaxCombo;
        document.getElementById('res-elapsed-time').innerText = `${matchTimeCount}초`;
        document.getElementById('res-total-score').innerText = `${accumulativeScore}점`;

        const townStr = currentSigun ? `${currentSido} ${currentSigun}` : currentSido;
        document.getElementById('res-contrib-target').innerText = `📍 ${townStr} 국가대표 기여 포인트`;
        document.getElementById('res-contrib-pts').innerText = `+${accumulativeScore.toLocaleString()}`;

        const payload = {
            nickname: userNickname,
            sido: currentSido,
            sigun: currentSigun,
            score: accumulativeScore,
            correctCount: matchCorrectCount,
            maxCombo: matchMaxCombo,
            timestamp: Date.now()
        };

        if(isFirebaseActive) {
            db.collection("match_records").add(payload).then(() => {
                computeDynamicMultidimensionalRankings();
            }).catch(err => {
                console.error("데이터 기록 전송 실패, 캐시 강제 변환", err);
                computeDynamicMultidimensionalRankings();
            });
        } else {
            let records = JSON.parse(localStorage.getItem("mock_match_records") || "[]");
            records.push(payload);
            localStorage.setItem("mock_match_records", JSON.stringify(records));
            computeDynamicMultidimensionalRankings();
        }
    }

    // 5. 정밀 다차원 순위 동적 연산 알고리즘 (가짜 데이터 원천 차단)
    function computeDynamicMultidimensionalRankings() {
        if(isFirebaseActive) {
            db.collection("match_records").get().then(snap => {
                let recordsList = [];
                snap.forEach(doc => recordsList.push(doc.data()));
                executeRankingMatrixCalculation(recordsList);
            });
        } else {
            let recordsList = JSON.parse(localStorage.getItem("mock_match_records") || "[]");
            executeRankingMatrixCalculation(recordsList);
        }
    }

    function executeRankingMatrixCalculation(list) {
        // 내 스코어와 동일 스코어 정렬 기준 컴파일
        // 1. 전국 개인 순위 계산
        let sortedNational = [...list].sort((x, y) => y.score - x.score);
        let nationalRank = sortedNational.findIndex(r => r.nickname === userNickname && r.score === accumulativeScore) + 1;
        if(nationalRank <= 0) nationalRank = 1;

        // 2. 시도 내 개인 순위 계산
        let sortedSidoList = [...list].filter(r => r.sido === currentSido).sort((x, y) => y.score - x.score);
        let sidoRank = sortedSidoList.findIndex(r => r.nickname === userNickname && r.score === accumulativeScore) + 1;
        if(sidoRank <= 0) sidoRank = 1;

        document.getElementById('res-national-rank').innerText = `전국 ${nationalRank}위`;
        document.getElementById('res-sido-rank').innerText = `${currentSido} ${sidoRank}위`;

        // 3. 시군구 순위 계산 (광역시 등 하위 없을 시 히든 패스)
        const rowSigun = document.getElementById('res-rank-sigun-row');
        if(!currentSigun) {
            rowSigun.style.display = "none";
        } else {
            rowSigun.style.display = "flex";
            let sortedSigunList = [...list].filter(r => r.sido === currentSido && r.sigun === currentSigun).sort((x, y) => y.score - x.score);
            let sigunRank = sortedSigunList.findIndex(r => r.nickname === userNickname && r.score === accumulativeScore) + 1;
            if(sigunRank <= 0) sigunRank = 1;
            document.getElementById('res-sigun-rank').innerText = `${currentSigun} ${sigunRank}위`;
        }
    }

    // 6. 실시간 동기화 전국 랭킹 보드 대시보드 스위칭 컴포넌트
    function switchDashboardView() {
        switchActiveScreen('screen-dashboard');
        
        if(isFirebaseActive) {
            db.collection("match_records").get().then(snap => {
                let recordsList = [];
                snap.forEach(doc => recordsList.push(doc.data()));
                compileDashboardVisualMetrics(recordsList);
            });
        } else {
            let recordsList = JSON.parse(localStorage.getItem("mock_match_records") || "[]");
            compileDashboardVisualMetrics(recordsList);
        }
    }

    function compileDashboardVisualMetrics(list) {
        // 권역 통합 테이블 스탯 빌드
        let regionScores = {
            "서울특별시": { score: 0, users: 0 }, "경기도": { score: 0, users: 0 },
            "강원도": { score: 0, users: 0 }, "충청권": { score: 0, users: 0 },
            "전라권": { score: 0, users: 0 }, "경상권": { score: 0, users: 0 },
            "제주도": { score: 0, users: 0 }
        };

        list.forEach(r => {
            const mappedRegion = mapRegionBinding[r.sido] || "서울특별시";
            if(regionScores[mappedRegion]) {
                regionScores[mappedRegion].score += r.score;
                regionScores[mappedRegion].users += 1;
            }
        });

        // 리스트 정렬 변환
        let sortedDashboard = [];
        for(let name in regionScores) {
            sortedDashboard.push({ name, ...regionScores[name] });
        }
        sortedDashboard.sort((x, y) => y.score - x.score);

        // 상단 하이라이트 요약 대시보드 적용
        const myMapTarget = mapRegionBinding[currentSido];
        const myRegionRankIdx = sortedDashboard.findIndex(d => d.name === myMapTarget) + 1;
        const displayTownText = currentSigun ? `${currentSido} ${currentSigun}` : currentSido;

        document.getElementById('dash-my-status-banner').innerHTML = `
            🏆 내 소속: <strong>${displayTownText}</strong> | 대표 권역: <strong>${myMapTarget}</strong><br>
            🚀 현재 우리 권역 순위: <span style="text-decoration:underline; font-weight:bold;">전국 ${myRegionRankIdx}위</span> (${regionScores[myMapTarget].score.toLocaleString()}점)
        `;

        // SVG 지도 하이라이팅 연출 라벨 처리 및 색상 매핑 분기 작동
        document.querySelectorAll('.svg-region-path').forEach(p => {
            p.className.baseVal = "svg-region-path"; // 초기화
        });

        sortedDashboard.forEach((data, i) => {
            const rank = i + 1;
            const pathEl = document.getElementById(`svg-map-${data.name}`);
            if(pathEl) {
                if(rank === 1) pathEl.classList.add('rank-gold-color');
                else if(rank === 2) pathEl.classList.add('rank-silver-color');
                else if(rank === 3) pathEl.classList.add('rank-bronze-color');
                else pathEl.classList.add('rank-normal-color');
            }
        });

        // 내 표적지 무한 점멸 유도 바인딩
        const myPathElement = document.getElementById(`svg-map-${myMapTarget}`);
        if(myPathElement) {
            myPathElement.classList.add('my-target-blink');
        }

        // 스크롤 리스트 돔 노드 삽입
        const listbox = document.getElementById('dash-ranking-listbox');
        listbox.innerHTML = "";

        sortedDashboard.forEach((data, index) => {
            const rank = index + 1;
            const item = document.createElement('div');
            item.className = "rank-item-flex";
            if(data.name === myMapTarget) {
                item.className = "rank-item-flex my-town-highlight";
            }

            let badgeStyle = "circle-badge";
            if(rank === 1) badgeStyle += " bg1";
            if(rank === 2) badgeStyle += " bg2";
            if(rank === 3) badgeStyle += " bg3";

            item.innerHTML = `
                <div>
                    <span class="${badgeStyle}">${rank}</span>
                    <span style="font-weight:bold;">${data.name}</span>
                </div>
                <div style="text-align:right;">
                    <span style="color:var(--main-neon-blue); font-weight:bold;">${data.score.toLocaleString()} PTS</span><br>
                    <span style="font-size:0.75rem; color:#888;">참가인원 ${data.users}명</span>
                </div>
            `;
            listbox.appendChild(item);
        });
    }

    function returnToMainHome() {
        switchActiveScreen('screen-start');
        renderLiveMetaStatusDashboard();
    }

    // 로컬 디바이스 테스트 지원용 가상 DB 시드 빌더
    function initializeMockDatabase() {
        let records = localStorage.getItem("mock_match_records");
        if(!records) {
            const mockSeed = [
                { nickname: "경기지사", sido: "경기도", sigun: "수원시", score: 1350, correctCount: 12, maxCombo: 6, timestamp: Date.now() },
                { nickname: "서울스타", sido: "서울특별시", sigun: "", score: 1600, correctCount: 14, maxCombo: 9, timestamp: Date.now() },
                { nickname: "해운대파이터", sido: "부산광역시", sigun: "", score: 1200, correctCount: 11, maxCombo: 5, timestamp: Date.now() }
            ];
            localStorage.setItem("mock_match_records", JSON.stringify(mockSeed));
        }
    }
</script>

