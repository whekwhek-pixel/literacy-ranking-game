<!DOCTYPE html>

<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>대한민국 문해력 지역 대항전 V4</title>
    <link href="https://fonts.googleapis.com/css2?family=Black+Han+Sans&family=Jua&family=Noto+Sans+KR:wght@500;800&display=swap" rel="stylesheet">

<script src="https://www.gstatic.com/firebasejs/9.22.1/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.22.1/firebase-firestore-compat.js"></script>

<style>
    :root {
        --bg-dark-blue: #1A1B2F;
        --main-neon-blue: #00F0FF;
        --main-yellow: #FFD166;
        --main-green: #06D6A0;
        --point-red: #EF476F;
        --point-purple: #8338EC;
        --text-light: #F8F9FA;
        --card-dark: #242642;
        
        --rank-gold: #FFD700;
        --rank-silver: #C0C0C0;
        --rank-bronze: #CD7F32;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
        font-family: 'Noto Sans KR', sans-serif;
        -webkit-user-select: none;
        user-select: none;
    }

    body {
        background-color: #0B0C10;
        color: var(--text-light);
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        overflow: hidden;
    }

    /* 390px 스마트폰 세로 화면부터 완벽 유동 반응하는 모바일 컨테이너 */
    .game-container {
        width: 100%;
        max-width: 420px;
        height: 100vh;
        max-height: 880px;
        background: linear-gradient(180deg, var(--bg-dark-blue) 0%, #111222 100%);
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        border: 3px solid #333;
        box-shadow: 0 20px 50px rgba(0,0,0,0.6);
    }

    @media (min-width: 421px) {
        .game-container {
            border-radius: 20px;
            height: 94vh;
        }
    }

    /* 스크린 기본 액션 클래스 */
    .screen {
        display: none;
        flex-direction: column;
        width: 100%;
        height: 100%;
        padding: 18px;
        position: absolute;
        top: 0; left: 0;
        overflow-y: auto;
    }

    .screen.active {
        display: flex;
        animation: screenFadeIn 0.3s ease-out forwards;
    }

    .font-title { font-family: 'Black Han Sans', sans-serif; letter-spacing: 0.5px; }
    .font-ui { font-family: 'Jua', sans-serif; }

    /* 대항전 시그니처 네온 스타일 공통 버튼 */
    .btn-action {
        width: 100%;
        padding: 14px;
        font-size: 1.4rem;
        border: 3px solid var(--text-light);
        border-radius: 14px;
        cursor: pointer;
        color: var(--text-light);
        box-shadow: 0 5px 0 #000;
        transition: all 0.05s ease;
        position: relative;
        top: 0;
    }
    .btn-action:active {
        top: 4px;
        box-shadow: 0 1px 0 #000;
    }

    /* --- 1. 대항전 시작 정보 입력 화면 --- */
    #screen-start { justify-content: space-between; align-items: center; text-align: center; }
    .main-header-group { margin-top: 15px; }
    .main-header-group h1 {
        font-size: 2.5rem;
        color: var(--main-neon-blue);
        text-shadow: 0 0 10px rgba(0,240,255,0.5), 3px 3px 0 var(--point-purple);
        line-height: 1.2;
    }
    .main-header-group p { font-size: 1.05rem; color: var(--main-yellow); margin-top: 5px; }

    .form-info-box {
        width: 100%;
        background: var(--card-dark);
        border: 2px solid #3d406b;
        border-radius: 16px;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 12px;
        box-shadow: inset 0 0 10px rgba(0,0,0,0.5);
    }
    .form-label { font-size: 1.1rem; color: var(--text-light); text-align: left; margin-bottom: 2px; font-weight: bold; }
    .input-text {
        width: 100%; padding: 11px; font-size: 1.1rem; background: #0F101D; color: #fff;
        border: 2.5px solid var(--main-neon-blue); border-radius: 10px; outline: none; text-align: center;
    }
    .select-row { display: flex; gap: 8px; }
    .select-element {
        flex: 1; padding: 11px; font-size: 1.05rem; background: #0F101D; color: #fff;
        border: 2.5px solid #3d406b; border-radius: 10px; outline: none; cursor: pointer;
    }
    .select-element:focus { border-color: var(--main-neon-blue); }

    /* 실시간 인포그래픽 보드 스타일 */
    .live-status-board {
        width: 100%; background: rgba(0,0,0,0.4); border: 2px solid #222; border-radius: 12px; padding: 10px; margin-bottom: 12px;
    }
    .status-board-title { font-size: 0.95rem; color: var(--main-neon-blue); text-align: left; margin-bottom: 6px; font-weight: bold; }
    .status-row { display: flex; justify-content: space-between; padding: 4px 0; font-size: 0.85rem; border-bottom: 1px solid #222; }
    .status-row:last-child { border: none; }

    /* --- 2. 실시간 대항전 퀴즈 보드 및 헤더 --- */
    .game-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 5px; }
    .q-badge { background: var(--point-purple); color: white; padding: 4px 10px; border-radius: 8px; font-size: 1rem; border: 1.5px solid #fff; }
    .score-realtime { font-size: 1.15rem; color: var(--main-neon-blue); }

    .progress-outer { width: 100%; height: 10px; background: #111; border-radius: 5px; overflow: hidden; margin-bottom: 8px; border: 1px solid #333; }
    .progress-inner { height: 100%; width: 0%; background: var(--main-green); transition: width 0.2s linear; }

    .timer-widget { display: flex; align-items: center; justify-content: center; gap: 8px; background: rgba(0,0,0,0.3); padding: 4px 12px; border-radius: 15px; border: 1.5px solid #333; margin-bottom: 10px; font-size: 0.9rem; align-self: center; }
    .timer-track { width: 80px; height: 8px; background: #222; border-radius: 4px; overflow: hidden; }
    .timer-fill { width: 100%; height: 100%; background: var(--point-red); }

    .quiz-card {
        background: var(--card-dark); border: 2.5px solid #3d406b; border-radius: 16px;
        padding: 16px; min-height: 95px; display: flex; flex-direction: column;
        justify-content: center; align-items: center; text-align: center; position: relative; margin-bottom: 12px;
    }
    .quiz-tag { position: absolute; top: -11px; background: var(--main-neon-blue); color: #000; padding: 1px 8px; border-radius: 6px; font-size: 0.8rem; font-weight: bold; }
    .quiz-text { font-size: 1.15rem; font-weight: 800; line-height: 1.45; word-break: keep-all; }

    .zone-interactive { display: flex; flex-direction: column; gap: 8px; flex-grow: 1; position: relative; }
    
    /* 객관식 레이아웃 전용 */
    .btn-choice {
        background: #1B1C33; border: 2px solid #3d406b; border-radius: 12px;
        padding: 11px 14px; font-size: 1rem; text-align: left; cursor: pointer; color: white;
        transition: all 0.1s; display: flex; align-items: center;
    }
    .btn-choice:active { background: #252746; border-color: var(--main-neon-blue); }
    .choice-idx { background: #000; width: 22px; height: 22px; border-radius: 50%; display: inline-flex; justify-content: center; align-items: center; margin-right: 10px; border: 1.5px solid var(--main-neon-blue); font-size: 0.8rem; font-weight: bold; color: var(--main-neon-blue); }

    /* 주관식 구성 */
    .sub-container { display: flex; flex-direction: column; gap: 8px; width: 100%; }

    /* 완벽 양방향 & 터치 모바일 지원 선긋기 캔버스 시스템 */
    .matching-board { display: flex; justify-content: space-between; position: relative; width: 100%; height: 240px; }
    .canvas-overlay { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 5; }
    .match-column { display: flex; flex-direction: column; justify-content: space-between; width: 44%; height: 100%; z-index: 6; }
    
    .node-box {
        background: #1B1C33; border: 2px solid #3d406b; border-radius: 10px;
        padding: 8px; font-size: 0.85rem; text-align: center; color: white;
        cursor: pointer; min-height: 44px; display: flex; align-items: center; justify-content: center;
        position: relative; word-break: keep-all; transition: background 0.15s;
    }
    .node-box.selected { background: #2E2F54; border-color: var(--main-neon-blue); box-shadow: 0 0 8px rgba(0,240,255,0.4); }
    .node-box.linked-success { background: #13332B; border-color: var(--main-green); cursor: default; color: #8ce9c4; }

    /* --- 3. 중첩 차단 독점식 글로벌 콤보 알림창 --- */
    .combo-layer-overlay {
        position: absolute; top: 0; left: 0; width: 100%; height: 100%;
        display: none; justify-content: center; align-items: center; z-index: 100; pointer-events: none;
    }
    .combo-neon-card {
        background: #0B0C10; border: 3px solid var(--point-red); border-radius: 20px;
        padding: 16px 32px; text-align: center; box-shadow: 0 0 20px rgba(239,71,111,0.6);
        transform: scale(0.5); opacity: 0;
    }
    .combo-neon-card.run-animation { animation: comboAnimate 1.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }
    .combo-title-main { font-size: 2.2rem; color: var(--point-red); text-shadow: 0 0 10px rgba(239,71,111,0.4); }
    .combo-subtitle-sub { font-size: 1.4rem; color: var(--main-yellow); font-weight: bold; margin-top: 2px; }

    /* 깜빡이 플래시 효과 */
    .flash-screen { position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 80; display: none; }
    .flash-screen.correct-state { display: block; background: rgba(6, 214, 160, 0.12); animation: flashFade 0.35s ease-out; }

    /* --- 4. 정밀 다차원 플레이 완료 결과 화면 --- */
    .result-title { font-size: 2.2rem; color: var(--main-yellow); text-shadow: 0 0 8px rgba(255,209,102,0.3); text-align: center; margin-bottom: 10px; }
    .score-board-wrapper {
        background: var(--card-dark); border: 2px solid #3d406b; border-radius: 16px;
        padding: 12px; display: flex; flex-direction: column; gap: 6px; margin-bottom: 10px;
    }
    .board-row { display: flex; justify-content: space-between; padding: 6px 0; border-bottom: 1px dashed #3a3d5e; font-size: 0.95rem; }
    .board-row:last-child { border: none; font-size: 1.25rem; color: var(--main-neon-blue); font-weight: bold; }

    .contribution-badge-box {
        background: var(--point-purple); border: 2px solid #fff; border-radius: 14px;
        padding: 10px; text-align: center; margin-bottom: 12px; box-shadow: 0 0 10px rgba(131,56,236,0.5);
    }

    /* --- 5. 실시간 동적 SVG 지도 결합 대시보드 스크린 --- */
    .map-frame-box {
        width: 100%; height: 210px; background: #0F101D; border: 2px solid #3d406b;
        border-radius: 16px; display: flex; justify-content: center; align-items: center; padding: 4px; margin-bottom: 10px;
    }
    .map-engine-svg { width: 100%; height: 100%; }
    .svg-region-path { fill: #1D1E3A; stroke: #32345A; stroke-width: 1.5; transition: fill 0.3s; }
    
    /* 랭킹별 지도 색상 테마 피드백 구현 */
    .svg-region-path.rank-gold-color { fill: var(--rank-gold) !important; stroke: #fff; }
    .svg-region-path.rank-silver-color { fill: var(--rank-silver) !important; stroke: #fff; }
    .svg-region-path.rank-bronze-color { fill: var(--rank-bronze) !important; stroke: #fff; }
    .svg-region-path.rank-normal-color { fill: #2B4C7E; }
    
    /* 내 소속 지역 깜빡이 이펙트 무한 루프 */
    .svg-region-path.my-target-blink {
        stroke: var(--point-red) !important;
        stroke-width: 3.5 !important;
        animation: regionBlinkInfinite 0.8s infinite alternate;
    }

    .ranking-scroll-panel {
        background: #0F101D; border: 2px solid #222; border-radius: 12px;
        padding: 6px; flex-grow: 1; overflow-y: auto; display: flex; flex-direction: column; gap: 5px;
    }
    .rank-item-flex { display: flex; justify-content: space-between; align-items: center; padding: 6px 10px; border-radius: 8px; font-size: 0.9rem; background: #16172B; }
    .rank-item-flex.my-town-highlight { background: #342E1F; border: 1.5px solid var(--main-yellow); }
    
    .circle-badge { width: 20px; height: 20px; border-radius: 50%; background: #444; display: inline-flex; justify-content: center; align-items: center; color: white; font-size: 0.75rem; font-weight: bold; margin-right: 6px; }
    .circle-badge.bg1 { background: var(--rank-gold); color: #000; }
    .circle-badge.bg2 { background: var(--rank-silver); color: #000; }
    .circle-badge.bg3 { background: var(--rank-bronze); color: #fff; }

    /* 애니메이션 모음 */
    @keyframes screenFadeIn { from { opacity: 0; transform: scale(0.98); } to { opacity: 1; transform: scale(1); } }
    @keyframes flashFade { from { opacity: 1; } to { opacity: 0; } }
    @keyframes regionBlinkInfinite { from { fill-opacity: 1; } to { fill-opacity: 0.4; } }
    @keyframes comboAnimate {
        0% { transform: scale(0.4); opacity: 0; }
        15% { transform: scale(1.1); opacity: 1; }
        35% { transform: scale(1); }
        85% { transform: scale(1); opacity: 1; }
        100% { transform: scale(0.7); opacity: 0; }
    }
    .shake-body { animation: shakeAction 0.35s ease-in-out; }
    @keyframes shakeAction {
        0%, 100% { transform: translateX(0); }
        20%, 60% { transform: translateX(-6px); }
        40%, 80% { transform: translateX(6px); }
    }
</style>

</head>
<body>

<div class="game-container" id="game-viewport">
    <div class="flash-screen" id="feedback-flash-backdrop"></div>

<div class="combo-layer-overlay" id="global-combo-layer">
    <div class="combo-neon-card game-ui-font" id="combo-neon-box">
        <div class="combo-title-main" id="text-combo-title">3 COMBO</div>
        <div class="combo-subtitle-sub" id="text-combo-subtitle">GOOD!</div>
    </div>
</div>

<div class="screen active" id="screen-start">
    <div class="main-header-group">
        <h1 class="font-title">대한민국 문해력<br>지역 대항전</h1>
        <p class="font-ui">우리 지역의 자존심을 걸고 대전하라!</p>
    </div>

    <div class="live-status-board game-ui-font">
        <div class="status-board-title">📊 실시간 매치 참여 현황</div>
        <div class="status-row"><span>총 참여 플레이어 수</span><span id="meta-total-users" style="color:var(--main-neon-blue); font-weight:bold;">연결 중...</span></div>
        <div class="status-row"><span>현재 매치 1위 지역</span><span id="meta-top-region" style="color:var(--main-yellow);">연결 중...</span></div>
    </div>

    <div class="form-info-box font-ui">
        <div>
            <div class="form-label">🏅 국가대표 닉네임</div>
            <input type="text"
       class="input-text"
       id="input-nickname"
       placeholder="수원 고수 김세종">
        </div>
        <div>
            <div class="form-label">📍 소속 지역 선택 (실제 행정구역)</div>
            <div class="select-row">
                <select class="select-element" id="form-sido" onchange="synchronizeAdministrativeDistricts()"></select>
                <select class="select-element" id="form-sigun"></select>
            </div>
        </div>
    </div>

    <div style="width: 100%; margin-bottom: 10px;">
        <button class="btn-action font-ui" style="background: var(--main-neon-blue); color: #000; font-size:1.6rem;" onclick="validateAndInitializeGame()">대항전 출전!</button>
    </div>
</div>

<div class="screen" id="screen-match">
    <div class="game-header font-ui">
        <div class="q-badge" id="hud-q-index">Q. 1/15</div>
        <div class="score-realtime">MATCH PTS: <span id="hud-score" style="font-weight:bold;">0</span></div>
    </div>

    <div class="progress-outer"><div class="progress-inner" id="hud-progress-fill"></div></div>

    <div class="timer-widget font-ui">
        <span>⏱️ LIMIT</span>
        <div class="timer-track"><div class="timer-fill" id="hud-timer-fill"></div></div>
        <span id="hud-timer-text">30s</span>
    </div>

    <div class="quiz-card">
        <div class="quiz-tag font-ui" id="hud-quiz-cat">낱말의 뜻</div>
        <div class="quiz-text" id="hud-quiz-question">문제를 불러오는 중입니다.</div>
    </div>

    <div class="zone-interactive" id="hud-interactive-zone"></div>
</div>

<div class="screen" id="screen-result">
    <h2 class="font-title result-title">MATCH FINISHED</h2>
    
    <div class="score-board-wrapper font-ui">
        <div class="board-row"><span>정답 맞춤 수</span><span id="res-correct-cnt" style="color:var(--main-green);">0 / 15</span></div>
        <div class="board-row"><span>최대 연속 콤보</span><span id="res-max-combo" style="color:var(--point-red);">0</span></div>
        <div class="board-row"><span>최종 소요 시간</span><span id="res-elapsed-time">0초</span></div>
        <div class="board-row"><span>대항전 획득 총점</span><span id="res-total-score">0점</span></div>
    </div>

    <div class="contribution-badge-box font-ui">
        <div style="font-size: 0.95rem; color:#eee;" id="res-contrib-target">서울특별시 대표 기여도</div>
        <div style="font-size: 2rem; font-weight: bold; color: var(--main-yellow); margin-top: 4px;" id="res-contrib-pts">+0</div>
        <div style="font-size: 0.85rem; color: #ced4da; margin-top: 2px;">⚡ Firestore 동시 동기화 완료!</div>
    </div>

    <div class="score-board-wrapper font-ui" style="background:#15162B; border-color:var(--main-neon-blue);">
        <div style="font-size:0.9rem; color:var(--main-neon-blue); font-weight:bold; margin-bottom:4px;">🏆 실시간 연산 내 매치 순위</div>
        <div class="board-row" style="font-size:0.9rem;"><span>전국 개인 순위</span><span id="res-rank-national" style="color:#fff;">계산 중...</span></div>
        <div class="board-row" style="font-size:0.9rem;"><span>시·도 권역 순위</span><span id="res-rank-sido" style="color:#fff;">계산 중...</span></div>
        <div class="board-row" style="font-size:0.9rem;" id="res-rank-sigun-row"><span>시·군·구 순위</span><span id="res-rank-sigun" style="color:#fff;">계산 중...</span></div>
    </div>

    <button class="btn-action font-ui" style="background: var(--main-green); color:#000; margin-bottom: 8px;" onclick="switchDashboardView()">전국 대항전 현황판</button>
    <button class="btn-action font-ui" style="background: #495057; font-size:1.1rem; padding:8px;" onclick="returnToMainHome()">처음으로</button>
</div>

<div class="screen" id="screen-dashboard">
    <h2 class="font-title result-title" style="font-size:1.6rem; margin-bottom:6px; color:var(--main-neon-blue);">🗺️ 전국 대항전 대시보드</h2>
    
    <div class="contribution-badge-box font-ui" id="dash-my-status-banner" style="background:var(--main-yellow); color:#000; font-size:0.95rem; padding:8px; margin-bottom:8px; box-shadow:none;">
        집계 데이터 정산 중...
    </div>

    <div class="map-frame-box">
        <svg class="map-engine-svg" viewBox="0 0 120 150">
            <path id="svg-map-서울특별시" class="svg-region-path" d="M40,30 L58,28 L55,42 L42,45 Z" />
            <path id="svg-map-경기도" class="svg-region-path" d="M25,20 L60,20 L62,55 L40,65 L20,50 Z" />
            <path id="svg-map-강원도" class="svg-region-path" d="M60,15 L95,20 L85,55 L65,50 Z" />
            <path id="svg-map-충청권" class="svg-region-path" d="M20,55 L62,60 L55,85 L30,90 Z" />
            <path id="svg-map-경상권" class="svg-region-path" d="M60,62 L100,60 L90,115 L50,110 Z" />
            <path id="svg-map-전라권" class="svg-region-path" d="M15,92 L52,90 L45,135 L10,130 Z" />
            <path id="svg-map-제주도" class="svg-region-path" d="M30,142 L55,142 L50,148 L28,148 Z" />
        </svg>
    </div>

    <div class="ranking-scroll-panel font-ui" id="dash-ranking-listbox"></div>

    <button class="btn-action font-ui" style="background: var(--point-purple); margin-top:10px; font-size:1.1rem; padding:10px;" onclick="returnToMainHome()">처음으로</button>
</div>

</div>

<script>
    const audioContextInstance = new (window.AudioContext || window.webkitAudioContext)();
    function triggerAudioNode(type) {
        if(audioContextInstance.state === 'suspended') audioContextInstance.resume();
        const osc = audioContextInstance.createOscillator();
        const gain = audioContextInstance.createGain();
        osc.connect(gain); gain.connect(audioContextInstance.destination);

        if(type === 'correct') { // 딩동
            osc.type = 'sine';
            osc.frequency.setValueAtTime(523.25, audioContextInstance.currentTime);
            osc.frequency.setValueAtTime(659.25, audioContextInstance.currentTime + 0.08);
            gain.gain.setValueAtTime(0.2, audioContextInstance.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.01, audioContextInstance.currentTime + 0.35);
            osc.start(); osc.stop(audioContextInstance.currentTime + 0.35);
        } else if(type === 'wrong') { // 땡
            osc.type = 'sawtooth';
            osc.frequency.setValueAtTime(160, audioContextInstance.currentTime);
            osc.frequency.linearRampToValueAtTime(100, audioContextInstance.currentTime + 0.25);
            gain.gain.setValueAtTime(0.2, audioContextInstance.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.01, audioContextInstance.currentTime + 0.25);
            osc.start(); osc.stop(audioContextInstance.currentTime + 0.25);
        } else if(type === 'combo') { // 콤보 축하 업업비트
            osc.type = 'triangle';
            osc.frequency.setValueAtTime(440, audioContextInstance.currentTime);
            osc.frequency.setValueAtTime(554.37, audioContextInstance.currentTime + 0.05);
            osc.frequency.setValueAtTime(659.25, audioContextInstance.currentTime + 0.1);
            osc.frequency.setValueAtTime(880, audioContextInstance.currentTime + 0.15);
            gain.gain.setValueAtTime(0.2, audioContextInstance.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.01, audioContextInstance.currentTime + 0.4);
            osc.start(); osc.stop(audioContextInstance.currentTime + 0.4);
        } else if(type === 'finish') { // 대항전 완료 환호성 코드
            osc.type = 'sine';
            osc.frequency.setValueAtTime(392.00, audioContextInstance.currentTime);
            osc.frequency.exponentialRampToValueAtTime(1046.50, audioContextInstance.currentTime + 0.6);
            gain.gain.setValueAtTime(0.15, audioContextInstance.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.01, audioContextInstance.currentTime + 0.6);
            osc.start(); osc.stop(audioContextInstance.currentTime + 0.6);
        }
    }
